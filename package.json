{
  "name": "net-architect",
  "version": "1.3.0",
  "description": "The Network Engineer's Partner — offline subnet calc, VLSM, config gen, and real network testing",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "lint": "eslint src/",
    "build-icon": "node scripts/build-icon.js",
    "dist:win": "electron-builder --win",
    "dist:mac": "electron-builder --mac",
    "dist:linux": "electron-builder --linux",
    "dist": "electron-builder"
  },
  "keywords": [
    "network",
    "subnet",
    "vlsm",
    "electron",
    "engineer"
  ],
  "author": "Bruno Vasconcelos",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "eslint": "^8.56.0",
    "sharp": "^0.34.5",
    "to-ico": "^1.1.5"
  },
  "build": {
    "appId": "com.netarchitect.app",
    "productName": "Net Architect",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "build/icon.icns"
    },
    "linux": {
      "target": "AppImage",
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
